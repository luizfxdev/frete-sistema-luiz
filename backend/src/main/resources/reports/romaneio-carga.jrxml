<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="romaneio-carga" pageWidth="595" pageHeight="842"
              columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <parameter name="MOTORISTA_NOME" class="java.lang.String"/>
    <parameter name="VEICULO_PLACA"  class="java.lang.String"/>
    <parameter name="DATA_ROMANEIO"  class="java.lang.String"/>

    <field name="numero"                  class="java.lang.String"/>
    <field name="remetenteRazaoSocial"    class="java.lang.String"/>
    <field name="destinatarioRazaoSocial" class="java.lang.String"/>
    <field name="municipioDestino"        class="java.lang.String"/>
    <field name="ufDestino"               class="java.lang.String"/>
    <field name="pesoKg"                  class="java.math.BigDecimal"/>
    <field name="volumes"                 class="java.lang.Integer"/>

    <variable name="totalPeso" class="java.math.BigDecimal" calculation="Sum" resetType="Report">
        <variableExpression><![CDATA[$F{pesoKg}]]></variableExpression>
        <initialValueExpression><![CDATA[java.math.BigDecimal.ZERO]]></initialValueExpression>
    </variable>
    <variable name="totalVolumes" class="java.lang.Integer" calculation="Sum" resetType="Report">
        <variableExpression><![CDATA[$F{volumes}]]></variableExpression>
        <initialValueExpression><![CDATA[0]]></initialValueExpression>
    </variable>

    <title>
        <band height="100">
            <staticText>
                <reportElement x="0" y="0" width="555" height="28"/>
                <textElement textAlignment="Center"><font size="16" isBold="true"/></textElement>
                <text><![CDATA[NextLog — Romaneio de Carga]]></text>
            </staticText>
            <line><reportElement x="0" y="32" width="555" height="1"/></line>

            <staticText><reportElement x="0"   y="42" width="80"  height="16"/><textElement><font size="10" isBold="true"/></textElement><text><![CDATA[Motorista:]]></text></staticText>
            <textField><reportElement x="80"  y="42" width="475" height="16"/><textElement><font size="10"/></textElement><textFieldExpression><![CDATA[$P{MOTORISTA_NOME}]]></textFieldExpression></textField>

            <staticText><reportElement x="0"   y="60" width="80"  height="16"/><textElement><font size="10" isBold="true"/></textElement><text><![CDATA[Veículo:]]></text></staticText>
            <textField><reportElement x="80"  y="60" width="200" height="16"/><textElement><font size="10"/></textElement><textFieldExpression><![CDATA[$P{VEICULO_PLACA}]]></textFieldExpression></textField>

            <staticText><reportElement x="290" y="60" width="60"  height="16"/><textElement><font size="10" isBold="true"/></textElement><text><![CDATA[Data:]]></text></staticText>
            <textField><reportElement x="350" y="60" width="205" height="16"/><textElement><font size="10"/></textElement><textFieldExpression><![CDATA[$P{DATA_ROMANEIO}]]></textFieldExpression></textField>

            <line><reportElement x="0" y="84" width="555" height="1"/></line>
        </band>
    </title>

    <columnHeader>
        <band height="22">
            <staticText><reportElement x="0"   y="0" width="80"  height="20"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Número]]></text></staticText>
            <staticText><reportElement x="80"  y="0" width="140" height="20"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Remetente]]></text></staticText>
            <staticText><reportElement x="220" y="0" width="140" height="20"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Destinatário]]></text></staticText>
            <staticText><reportElement x="360" y="0" width="115" height="20"/><textElement><font isBold="true" size="9"/></textElement><text><![CDATA[Destino]]></text></staticText>
            <staticText><reportElement x="475" y="0" width="50"  height="20"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Peso (kg)]]></text></staticText>
            <staticText><reportElement x="525" y="0" width="30"  height="20"/><textElement textAlignment="Right"><font isBold="true" size="9"/></textElement><text><![CDATA[Vol.]]></text></staticText>
            <line><reportElement x="0" y="20" width="555" height="1"/></line>
        </band>
    </columnHeader>

    <detail>
        <band height="18">
            <textField><reportElement x="0"   y="0" width="80"  height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{numero}]]></textFieldExpression></textField>
            <textField><reportElement x="80"  y="0" width="140" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{remetenteRazaoSocial}]]></textFieldExpression></textField>
            <textField><reportElement x="220" y="0" width="140" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{destinatarioRazaoSocial}]]></textFieldExpression></textField>
            <textField><reportElement x="360" y="0" width="115" height="16"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{municipioDestino} + "/" + $F{ufDestino}]]></textFieldExpression></textField>
            <textField pattern="#,##0.00"><reportElement x="475" y="0" width="50" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{pesoKg}]]></textFieldExpression></textField>
            <textField><reportElement x="525" y="0" width="30" height="16"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$F{volumes}]]></textFieldExpression></textField>
        </band>
    </detail>

    <summary>
        <band height="60">
            <line><reportElement x="0" y="0" width="555" height="1"/></line>

            <staticText>
                <reportElement x="0" y="8" width="475" height="18"/>
                <textElement textAlignment="Right"><font isBold="true" size="10"/></textElement>
                <text><![CDATA[Total de peso (kg):]]></text>
            </staticText>
            <textField pattern="#,##0.00">
                <reportElement x="475" y="8" width="80" height="18"/>
                <textElement textAlignment="Right"><font isBold="true" size="10"/></textElement>
                <textFieldExpression><![CDATA[$V{totalPeso}]]></textFieldExpression>
            </textField>

            <staticText>
                <reportElement x="0" y="28" width="475" height="18"/>
                <textElement textAlignment="Right"><font isBold="true" size="10"/></textElement>
                <text><![CDATA[Total de volumes:]]></text>
            </staticText>
            <textField>
                <reportElement x="475" y="28" width="80" height="18"/>
                <textElement textAlignment="Right"><font isBold="true" size="10"/></textElement>
                <textFieldExpression><![CDATA[$V{totalVolumes}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
</jasperReport>