<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="fretes-em-aberto" pageWidth="842" pageHeight="595" orientation="Landscape"
              columnWidth="802" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">

    <parameter name="DATA_GERACAO" class="java.lang.String"/>

    <field name="numero"                   class="java.lang.String"/>
    <field name="remetenteRazaoSocial"     class="java.lang.String"/>
    <field name="destinatarioRazaoSocial"  class="java.lang.String"/>
    <field name="motoristaNome"            class="java.lang.String"/>
    <field name="municipioDestino"         class="java.lang.String"/>
    <field name="ufDestino"                class="java.lang.String"/>
    <field name="dataPrevisaoEntrega"      class="java.time.LocalDate"/>
    <field name="status"                   class="java.lang.Object"/>

    <variable name="diasAtraso" class="java.lang.Long" resetType="None">
        <variableExpression>
            <![CDATA[
            $F{dataPrevisaoEntrega} != null
                && java.time.LocalDate.now().isAfter($F{dataPrevisaoEntrega})
                ? java.time.temporal.ChronoUnit.DAYS.between($F{dataPrevisaoEntrega}, java.time.LocalDate.now())
                : 0L
            ]]>
        </variableExpression>
    </variable>

    <title>
        <band height="60">
            <staticText>
                <reportElement x="0" y="0" width="802" height="28"/>
                <textElement textAlignment="Left">
                    <font size="18" isBold="true"/>
                </textElement>
                <text><![CDATA[NextLog — Fretes em aberto]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="32" width="802" height="16"/>
                <textElement>
                    <font size="10"/>
                </textElement>
                <textFieldExpression><![CDATA["Gerado em: " + $P{DATA_GERACAO}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="24">
            <staticText><reportElement x="0"   y="0" width="100" height="24"/><textElement><font isBold="true" size="10"/></textElement><text><![CDATA[Número]]></text></staticText>
            <staticText><reportElement x="100" y="0" width="160" height="24"/><textElement><font isBold="true" size="10"/></textElement><text><![CDATA[Remetente]]></text></staticText>
            <staticText><reportElement x="260" y="0" width="160" height="24"/><textElement><font isBold="true" size="10"/></textElement><text><![CDATA[Destinatário]]></text></staticText>
            <staticText><reportElement x="420" y="0" width="140" height="24"/><textElement><font isBold="true" size="10"/></textElement><text><![CDATA[Motorista]]></text></staticText>
            <staticText><reportElement x="560" y="0" width="120" height="24"/><textElement><font isBold="true" size="10"/></textElement><text><![CDATA[Destino]]></text></staticText>
            <staticText><reportElement x="680" y="0" width="70"  height="24"/><textElement><font isBold="true" size="10"/></textElement><text><![CDATA[Previsão]]></text></staticText>
            <staticText><reportElement x="750" y="0" width="52"  height="24"/><textElement><font isBold="true" size="10"/></textElement><text><![CDATA[Atraso]]></text></staticText>
            <line><reportElement x="0" y="22" width="802" height="1"/></line>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField><reportElement x="0"   y="0" width="100" height="18"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{numero}]]></textFieldExpression></textField>
            <textField><reportElement x="100" y="0" width="160" height="18"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{remetenteRazaoSocial}]]></textFieldExpression></textField>
            <textField><reportElement x="260" y="0" width="160" height="18"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{destinatarioRazaoSocial}]]></textFieldExpression></textField>
            <textField><reportElement x="420" y="0" width="140" height="18"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{motoristaNome}]]></textFieldExpression></textField>
            <textField><reportElement x="560" y="0" width="120" height="18"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{municipioDestino} + "/" + $F{ufDestino}]]></textFieldExpression></textField>
            <textField pattern="dd/MM/yyyy"><reportElement x="680" y="0" width="70" height="18"/><textElement><font size="9"/></textElement><textFieldExpression><![CDATA[$F{dataPrevisaoEntrega}]]></textFieldExpression></textField>
            <textField><reportElement x="750" y="0" width="52" height="18"/><textElement textAlignment="Right"><font size="9"/></textElement><textFieldExpression><![CDATA[$V{diasAtraso} > 0 ? $V{diasAtraso} + " dias" : "—"]]></textFieldExpression></textField>
        </band>
    </detail>

    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="0" y="0" width="802" height="16"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
</jasperReport>